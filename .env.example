# 로컬 테스트용. 실제 값으로 채운 뒤 `.env`로 복사하세요 (.env는 깃에 올리지 않음).
# GitHub Actions에서는 이 값들을 Settings → Secrets and variables → Actions 에 등록합니다.

# 콘텐츠 생성 (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn (개인 프로필 게시) — w_member_social + openid profile 스코프
LINKEDIN_ACCESS_TOKEN=

# Facebook 페이지
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Instagram 비즈니스 계정 ID (비우면 FB 페이지에서 자동 조회)
IG_USER_ID=

# Instagram 게시용 공개 이미지 URL (로컬 테스트 시에만 수동 지정. Actions는 자동 생성)
IMAGE_PUBLIC_URL=
