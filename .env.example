# 로컬 테스트용. 실제 값으로 채운 뒤 `.env`로 복사하세요 (.env는 깃에 올리지 않음).
# GitHub Actions에서는 이 값들을 Settings → Secrets and variables → Actions 에 등록합니다.

# 콘텐츠 생성 (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn (개인 프로필 게시)
# [권장] 자동 갱신: refresh_token + client 자격증명 (60일마다 수동 갱신 불필요)
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# [폴백] 위 3개가 없을 때만 쓰는 수동 60일 토큰
LINKEDIN_ACCESS_TOKEN=

# Instagram (게시)
# [권장] Instagram 로그인 토큰 — 있으면 graph.instagram.com 으로 게시(FB 페이지·비즈니스 불필요)
INSTAGRAM_ACCESS_TOKEN=
IG_USER_ID=
# [폴백] FB 페이지 방식 — INSTAGRAM_ACCESS_TOKEN 이 없을 때만 사용
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# 캐러셀 슬라이드 공개 URL 베이스 (로컬 테스트 시에만 수동 지정. Actions는 자동 생성)
IMAGE_BASE_URL=
CACHE_BUST=1
